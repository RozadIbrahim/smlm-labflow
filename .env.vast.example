# Copy this to .env.vast and fill it.
# Never commit .env.vast.

VAST_API_KEY="PASTE_YOUR_VAST_API_KEY_HERE"

# GitHub repo
REPO_URL="https://github.com/YOUR_USERNAME/smlm-labflow.git"
REPO_NAME="smlm-labflow"

# Docker image built by GitHub Actions
DOCKER_IMAGE="ghcr.io/YOUR_USERNAME/smlm-labflow-vast:cuda121"

# SSH
SSH_KEY="$HOME/.ssh/vast_liteloc_ed25519"

# Vast defaults
DISK_GB="60"
GPU_QUERY_3090="gpu_name=RTX_3090 num_gpus=1 verified=true direct_port_count>=1 rentable=true disk_space>=40 reliability>0.95"
GPU_QUERY_4090="gpu_name=RTX_4090 num_gpus=1 verified=true direct_port_count>=1 rentable=true disk_space>=40 reliability>0.95"

# Local result destination
LOCAL_RESULTS_DIR="./vast_results"
