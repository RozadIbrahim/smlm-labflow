#!/usr/bin/env python3
"""
adapters/liteloc_adapter.py

General LiteLoc adapter for the SMLM LabFlow pipeline.

Public functions discovered by run_pipeline.py:

    calibrate:
        run_liteloc_calibration(...)
        run_calibration(...)
        calibrate_liteloc(...)
        run_calibrate(...)
        calibrate(...)

    train:
        run_liteloc_training(...)
        run_training(...)
        train_liteloc(...)
        run_train(...)
        train(...)

    infer:
        run_liteloc_one_movie(...)
        run_inference_one_movie(...)
        run_liteloc_inference(...)
        run_inference(...)
        run_liteloc(...)
        infer(...)

Design:
    - works with the new run_pipeline.py backend_config/resolver bridge
    - still supports the older config_resolver.py fallback
    - uses the active Python interpreter/environment through sys.executable
    - avoids shell=True; paths with spaces are passed safely as list arguments
    - writes logs and status JSON files for every backend step
    - does not pretend success if an expected artifact is missing

Important:
    Calibration/training ports must be valid Python scripts from your LiteLoc checkout.
    If the original LiteLoc demo scripts are hardcoded, this adapter can run them and
    capture logs, but the LiteLoc script itself must support or already know which
    files/YAML to use. The adapter then searches for produced artifacts and copies
    them into the current run's results folder.
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import time
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, Iterable, List, Mapping, Optional, Sequence, Tuple

try:
    import yaml
except Exception as exc:  # pragma: no cover
    raise ImportError("PyYAML is required by adapters/liteloc_adapter.py") from exc


# =============================================================================
# Small utilities
# =============================================================================


def now_iso() -> str:
    return datetime.now().isoformat(timespec="seconds")


def get_nested(data: Mapping[str, Any], *keys: str, default: Any = None) -> Any:
    current: Any = data
    for key in keys:
        if not isinstance(current, Mapping):
            return default
        current = current.get(key)
    return default if current is None else current


def set_nested(data: Dict[str, Any], keys: Sequence[str], value: Any) -> None:
    current = data
    for key in keys[:-1]:
        if key not in current or not isinstance(current[key], dict):
            current[key] = {}
        current = current[key]
    current[keys[-1]] = value


def write_json(data: Mapping[str, Any], path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        json.dumps(data, indent=2, ensure_ascii=False, default=str),
        encoding="utf-8",
    )


def write_yaml(data: Mapping[str, Any], path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        yaml.safe_dump(dict(data), handle, sort_keys=False, allow_unicode=True)


def resolve_path(value: str | Path, base_dir: Optional[Path] = None) -> Path:
    path = Path(str(value)).expanduser()
    if path.is_absolute():
        return path.resolve()
    if base_dir is not None:
        return (base_dir / path).resolve()
    return path.resolve()


def optional_path(value: Any, base_dir: Optional[Path] = None) -> Optional[Path]:
    if value is None:
        return None
    text = str(value).strip()
    if not text:
        return None
    return resolve_path(text, base_dir=base_dir)


def path_exists_or_none(path: Optional[Path]) -> Optional[Path]:
    if path is None:
        return None
    return path if path.exists() else None


def as_bool(value: Any, default: bool = False) -> bool:
    if isinstance(value, bool):
        return value
    if value is None:
        return default
    text = str(value).strip().lower()
    if text in {"1", "true", "yes", "on"}:
        return True
    if text in {"0", "false", "no", "off"}:
        return False
    return default


def snapshot_files(folder: Path) -> set[Path]:
    if not folder.exists():
        return set()
    return {p.resolve() for p in folder.rglob("*") if p.is_file()}


def add_liteloc_to_syspath_and_env(repo_dir: Path) -> Dict[str, str]:
    repo_dir = repo_dir.expanduser().resolve()
    repo_str = str(repo_dir)

    if repo_str not in sys.path:
        sys.path.insert(0, repo_str)

    env = os.environ.copy()
    old_pythonpath = env.get("PYTHONPATH", "")
    parts = [repo_str]
    if old_pythonpath:
        parts.append(old_pythonpath)
    env["PYTHONPATH"] = os.pathsep.join(parts)
    return env


# =============================================================================
# Runtime config resolution
# =============================================================================


@dataclass
class LiteLocPorts:
    infer: Optional[Path]
    train: Optional[Path]
    calibrate: Optional[Path]


@dataclass
class LiteLocRuntime:
    repo_dir: Path
    ports: LiteLocPorts
    backend_config: Dict[str, Any]


def _candidate_root_values(profile: Mapping[str, Any], backend_config: Mapping[str, Any]) -> List[Any]:
    return [
        backend_config.get("liteloc_root"),
        backend_config.get("root"),
        get_nested(backend_config, "paths", "root"),
        get_nested(backend_config, "backend_paths", "liteloc", "root"),
        get_nested(backend_config, "backend_paths", "root"),
        get_nested(profile, "liteloc", "root"),
        get_nested(profile, "liteloc", "repo_dir"),
        get_nested(profile, "backend", "root"),
        get_nested(profile, "backend", "liteloc_root"),
    ]


def _candidate_port_values(
    profile: Mapping[str, Any],
    backend_config: Mapping[str, Any],
    step: str,
) -> List[Any]:
    aliases = {
        "calibrate": ["calibrate", "calibration", "calibrate_script", "calibration_script"],
        "train": ["train", "training", "train_script", "training_script"],
        "infer": ["infer", "inference", "infer_script", "inference_script"],
    }[step]

    values: List[Any] = []
    for alias in aliases:
        values.extend(
            [
                backend_config.get(alias),
                backend_config.get(f"{alias}_port"),
                get_nested(backend_config, "ports", alias),
                get_nested(backend_config, "backend_paths", "liteloc", "ports", alias),
                get_nested(profile, "liteloc", alias),
                get_nested(profile, "liteloc", "ports", alias),
                get_nested(profile, "backend", "ports", alias),
            ]
        )
    return values


def _default_port_for_step(step: str) -> Optional[str]:
    defaults = {
        "calibrate": "demo/demo3_calibrate_psf/demo3_psf_calibration.py",
        "train": "demo/demo1_astig_npc/liteloc_train_demo1.py",
        "infer": "demo/demo1_astig_npc/liteloc_infer_demo1.py",
    }
    return defaults.get(step)


def _resolve_first_existing_path(
    values: Iterable[Any],
    base_dir: Optional[Path],
    required: bool,
    label: str,
) -> Optional[Path]:
    attempted: List[str] = []

    for value in values:
        path = optional_path(value, base_dir=base_dir)
        if path is None:
            continue
        attempted.append(str(path))
        if path.exists():
            return path

    if required:
        raise FileNotFoundError(
            f"Could not resolve required {label}. Tried: {attempted if attempted else 'nothing'}"
        )
    return None


def load_old_liteloc_backend_config_from_config_resolver() -> Optional[Any]:
    """
    Backward-compatible fallback for your older adapter design.

    Expected old resolver function:
        config_resolver.load_liteloc_backend_config()

    Expected returned object:
        backend_config.root
        backend_config.ports.infer/train/calibrate
    """
    try:
        from config_resolver import load_liteloc_backend_config  # type: ignore
    except Exception:
        return None

    try:
        return load_liteloc_backend_config()
    except Exception:
        return None


def runtime_from_old_config_resolver() -> Optional[LiteLocRuntime]:
    cfg = load_old_liteloc_backend_config_from_config_resolver()
    if cfg is None:
        return None

    try:
        repo_dir = Path(cfg.root).expanduser().resolve()
        ports_obj = getattr(cfg, "ports", None)
        ports = LiteLocPorts(
            infer=optional_path(getattr(ports_obj, "infer", None), base_dir=repo_dir),
            train=optional_path(getattr(ports_obj, "train", None), base_dir=repo_dir),
            calibrate=optional_path(getattr(ports_obj, "calibrate", None), base_dir=repo_dir),
        )
        return LiteLocRuntime(
            repo_dir=repo_dir,
            ports=ports,
            backend_config={
                "status": "loaded_from_old_config_resolver",
                "root": str(repo_dir),
                "ports": {
                    "infer": str(ports.infer) if ports.infer else "",
                    "train": str(ports.train) if ports.train else "",
                    "calibrate": str(ports.calibrate) if ports.calibrate else "",
                },
            },
        )
    except Exception:
        return None


def resolve_liteloc_runtime(
    profile: Dict[str, Any],
    backend_config: Optional[Dict[str, Any]] = None,
) -> LiteLocRuntime:
    """
    Resolve LiteLoc root and ports from new backend_config first, then old resolver.
    """
    backend_config = dict(backend_config or {})

    root = _resolve_first_existing_path(
        _candidate_root_values(profile, backend_config),
        base_dir=None,
        required=False,
        label="LiteLoc root",
    )

    if root is None:
        old_runtime = runtime_from_old_config_resolver()
        if old_runtime is not None:
            return old_runtime
        raise FileNotFoundError(
            "LiteLoc root is missing. Set one of:\n"
            "  adapters/backend_paths.yml -> liteloc.root\n"
            "  profile -> liteloc.root or liteloc.repo_dir\n"
            "  old config/local_paths.yaml via config_resolver.py"
        )

    repo_dir = root.resolve()

    ports = LiteLocPorts(
        infer=_resolve_first_existing_path(
            list(_candidate_port_values(profile, backend_config, "infer")) + [_default_port_for_step("infer")],
            base_dir=repo_dir,
            required=False,
            label="LiteLoc inference port",
        ),
        train=_resolve_first_existing_path(
            list(_candidate_port_values(profile, backend_config, "train")) + [_default_port_for_step("train")],
            base_dir=repo_dir,
            required=False,
            label="LiteLoc training port",
        ),
        calibrate=_resolve_first_existing_path(
            list(_candidate_port_values(profile, backend_config, "calibrate")) + [_default_port_for_step("calibrate")],
            base_dir=repo_dir,
            required=False,
            label="LiteLoc calibration port",
        ),
    )

    resolved = dict(backend_config)
    resolved.setdefault("status", "resolved_by_liteloc_adapter")
    resolved["root"] = str(repo_dir)
    resolved["ports"] = {
        "infer": str(ports.infer) if ports.infer else "",
        "train": str(ports.train) if ports.train else "",
        "calibrate": str(ports.calibrate) if ports.calibrate else "",
    }

    return LiteLocRuntime(repo_dir=repo_dir, ports=ports, backend_config=resolved)


# =============================================================================
# Artifact detection
# =============================================================================


def find_new_artifact(
    search_dirs: Sequence[Path],
    before_files: set[Path],
    suffixes: set[str],
    name_tokens: Sequence[str],
) -> Optional[Path]:
    candidates: List[Path] = []

    for folder in search_dirs:
        if not folder.exists():
            continue
        for path in folder.rglob("*"):
            if not path.is_file():
                continue
            resolved = path.resolve()
            if resolved in before_files:
                continue
            if path.suffix.lower() not in suffixes:
                continue
            if name_tokens and not any(token in path.name.lower() for token in name_tokens):
                continue
            candidates.append(resolved)

    if not candidates:
        return None

    return sorted(candidates, key=lambda p: p.stat().st_mtime, reverse=True)[0]


def copy_artifact_to_out_dir(artifact: Optional[Path], out_dir: Path, preferred_name: Optional[str] = None) -> str:
    if artifact is None:
        return ""

    out_dir.mkdir(parents=True, exist_ok=True)
    target = out_dir / (preferred_name or artifact.name)

    if artifact.resolve() != target.resolve():
        shutil.copy2(artifact, target)

    return str(target.resolve())


# =============================================================================
# Generic script runner
# =============================================================================


def run_python_script(
    *,
    script_path: Path,
    repo_dir: Path,
    log_path: Path,
    env: Dict[str, str],
    extra_args: Optional[Sequence[str]] = None,
) -> subprocess.CompletedProcess[str]:
    """
    Run a Python script without shell=True.

    Passing args as a list avoids path-with-space quoting issues inside Python.
    """
    if not script_path.exists():
        raise FileNotFoundError(f"LiteLoc script not found: {script_path}")

    cmd = [sys.executable, str(script_path)]
    if extra_args:
        cmd.extend(str(arg) for arg in extra_args)

    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a", encoding="utf-8") as log:
        log.write("Command:\n")
        log.write(" ".join(cmd) + "\n\n")
        log.flush()

        return subprocess.run(
            cmd,
            cwd=str(repo_dir),
            env=env,
            stdout=log,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
            shell=False,
        )


# =============================================================================
# LiteLoc native YAML helpers: inference
# =============================================================================


def load_base_liteloc_yaml(base_yaml_path: Path) -> Dict[str, Any]:
    if not base_yaml_path.exists():
        raise FileNotFoundError(f"Base LiteLoc YAML not found: {base_yaml_path}")

    with base_yaml_path.open("r", encoding="utf-8") as handle:
        config = yaml.safe_load(handle) or {}

    if not isinstance(config, dict):
        raise ValueError(f"LiteLoc YAML must be a dictionary: {base_yaml_path}")

    config.setdefault("Loc_Model", {})
    config.setdefault("Multi_Process", {})
    return config


def detect_infer_execution(profile: Dict[str, Any], infer_port: Optional[Path]) -> str:
    value = str(get_nested(profile, "liteloc", "infer_execution", default="auto")).lower().strip()

    if value not in {"auto", "script", "module"}:
        raise ValueError("Invalid liteloc.infer_execution. Expected auto, script, or module.")

    if value in {"script", "module"}:
        return value

    if infer_port is None:
        return "script"

    if infer_port.name.lower() == "multi_process.py" or infer_port.parent.name.lower() == "network":
        return "module"

    return "script"


def build_runtime_liteloc_infer_yaml(
    input_path: Path,
    out_dir: Path,
    profile: Dict[str, Any],
    repo_dir: Path,
    backend_config: Optional[Dict[str, Any]] = None,
) -> Tuple[Path, Path, Dict[str, Any]]:
    backend_config = backend_config or {}
    out_dir.mkdir(parents=True, exist_ok=True)

    base_yaml_value = (
        backend_config.get("base_infer_yaml")
        or backend_config.get("infer_yaml")
        or get_nested(profile, "liteloc", "base_infer_yaml")
        or get_nested(profile, "liteloc", "infer_yaml")
        or get_nested(profile, "inference", "base_yaml")
        or "demo/demo1_astig_npc/infer_params_demo1.yaml"
    )
    base_yaml_path = resolve_path(base_yaml_value, base_dir=repo_dir)

    model_path_value = (
        backend_config.get("model_path")
        or backend_config.get("checkpoint_path")
        or get_nested(profile, "liteloc", "model_path")
        or get_nested(profile, "inference", "model_path")
    )

    if model_path_value is None:
        raise KeyError(
            "Missing LiteLoc model checkpoint. Add model_path to the resolved registry/backend config "
            "or to profile.liteloc.model_path / profile.inference.model_path."
        )

    model_path = resolve_path(model_path_value, base_dir=repo_dir)
    if not model_path.exists():
        raise FileNotFoundError(f"LiteLoc model checkpoint not found: {model_path}")

    raw_output_name = get_nested(profile, "output", "raw_output_name", default="liteloc_raw_output.csv")
    runtime_yaml_name = get_nested(profile, "output", "runtime_yaml_name", default="runtime_liteloc_infer.yaml")

    raw_output_path = out_dir / str(raw_output_name)
    runtime_yaml_path = out_dir / str(runtime_yaml_name)

    config = load_base_liteloc_yaml(base_yaml_path)
    config["Loc_Model"]["model_path"] = str(model_path)
    config["Multi_Process"]["image_path"] = str(input_path)
    config["Multi_Process"]["save_path"] = str(raw_output_path)

    runtime_sources = [
        ("time_block_gb", 1),
        ("batch_size", 64),
        ("sub_fov_size", 256),
        ("over_cut", 8),
        ("data_queue_size", 100),
        ("multi_gpu", False),
        ("num_producers", 1),
    ]

    for key, default in runtime_sources:
        config["Multi_Process"][key] = (
            backend_config.get(key)
            or get_nested(profile, "liteloc", "runtime", key)
            or get_nested(profile, "inference", key)
            or default
        )

    with runtime_yaml_path.open("w", encoding="utf-8") as handle:
        yaml.safe_dump(config, handle, sort_keys=False)

    resolved_config = {
        "base_yaml_path": str(base_yaml_path),
        "model_path": str(model_path),
        "runtime_yaml_path": str(runtime_yaml_path),
        "raw_output_path": str(raw_output_path),
        "multi_process": config.get("Multi_Process", {}),
    }
    return runtime_yaml_path, raw_output_path, resolved_config


# =============================================================================
# LiteLoc inference execution modes
# =============================================================================


def run_liteloc_inference_script_mode(
    *,
    infer_port: Path,
    runtime_yaml_path: Path,
    repo_dir: Path,
    env: Dict[str, str],
    log_path: Path,
) -> subprocess.CompletedProcess[str]:
    return run_python_script(
        script_path=infer_port,
        repo_dir=repo_dir,
        log_path=log_path,
        env=env,
        extra_args=["--infer_params_path", str(runtime_yaml_path)],
    )


def run_liteloc_inference_module_mode(
    *,
    runtime_yaml_path: Path,
    repo_dir: Path,
    log_path: Path,
) -> int:
    add_liteloc_to_syspath_and_env(repo_dir)

    with log_path.open("a", encoding="utf-8") as log:
        log.write("\nRunning LiteLoc inference in MODULE mode.\n")
        log.write(f"Runtime YAML: {runtime_yaml_path}\n\n")
        log.flush()

    try:
        import torch  # type: ignore
        from utils.help_utils import load_yaml_infer  # type: ignore
        from network import multi_process  # type: ignore
    except Exception as exc:
        with log_path.open("a", encoding="utf-8") as log:
            log.write("Failed to import LiteLoc modules.\n")
            log.write(repr(exc) + "\n")
        raise

    infer_params = load_yaml_infer(str(runtime_yaml_path))
    liteloc_model = torch.load(infer_params.Loc_Model.model_path, weights_only=False)
    mp = infer_params.Multi_Process

    t0 = time.time()
    analyzer = multi_process.CompetitiveSmlmDataAnalyzer_multi_producer(
        loc_model=liteloc_model,
        tiff_path=mp.image_path,
        output_path=mp.save_path,
        time_block_gb=mp.time_block_gb,
        batch_size=mp.batch_size,
        sub_fov_size=mp.sub_fov_size,
        over_cut=mp.over_cut,
        data_queue_size=mp.data_queue_size,
        multi_GPU=mp.multi_gpu,
        num_producers=mp.num_producers,
    )
    t1 = time.time()

    with log_path.open("a", encoding="utf-8") as log:
        log.write(f"LiteLoc module init time: {t1 - t0:.3f} seconds\n")
        log.flush()

    analyzer.start()
    t2 = time.time()

    with log_path.open("a", encoding="utf-8") as log:
        log.write(f"LiteLoc module analyze time: {t2 - t1:.3f} seconds\n")
        log.flush()

    return 0


# =============================================================================
# Calibration
# =============================================================================


def build_calibration_script_args(
    input_path: Path,
    out_dir: Path,
    profile: Dict[str, Any],
    backend_config: Dict[str, Any],
) -> List[str]:
    """
    Optional script args for a calibration port.

    Default is empty because many LiteLoc demo scripts are hardcoded.

    Profile override:
        liteloc.calibration_args:
          - --input
          - "{input}"
          - --output
          - "{output}"

    Backend config override:
        calibration_args: [...]
    """
    raw_args = backend_config.get("calibration_args") or get_nested(profile, "liteloc", "calibration_args", default=[])
    if not raw_args:
        return []
    if not isinstance(raw_args, list):
        raise ValueError("liteloc.calibration_args / calibration_args must be a list.")

    replacements = {
        "{input}": str(input_path),
        "{output}": str(out_dir),
        "{out_dir}": str(out_dir),
    }

    args: List[str] = []
    for item in raw_args:
        text = str(item)
        for key, value in replacements.items():
            text = text.replace(key, value)
        args.append(text)
    return args


def run_liteloc_calibration(
    input_path: str | Path,
    out_dir: str | Path,
    profile: Dict[str, Any],
    backend_config: Optional[Dict[str, Any]] = None,
    **_: Any,
) -> Dict[str, Any]:
    start_time = time.time()
    backend_config = dict(backend_config or {})
    input_path = Path(input_path).expanduser().resolve()
    out_dir = Path(out_dir).expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    runtime = resolve_liteloc_runtime(profile, backend_config)
    repo_dir = runtime.repo_dir
    calibrate_port = runtime.ports.calibrate

    log_path = out_dir / "liteloc_calibration.log"
    status_path = out_dir / "liteloc_calibration_adapter_status.json"

    if calibrate_port is None:
        result = {
            "backend_name": "liteloc",
            "backend_status": "failed",
            "calibrate_status": "failed",
            "input_path": str(input_path),
            "out_dir": str(out_dir),
            "liteloc_root": str(repo_dir),
            "calibrate_script": "",
            "calibration_file": "",
            "log_path": str(log_path),
            "message": "No LiteLoc calibration port/script found. Set ports.calibrate in adapters/backend_paths.yml.",
        }
        write_json(result, status_path)
        return result

    env = add_liteloc_to_syspath_and_env(repo_dir)
    env["LITELOC_CALIBRATION_INPUT"] = str(input_path)
    env["LITELOC_CALIBRATION_OUTPUT"] = str(out_dir)
    env["LITELOC_RUN_OUTPUT"] = str(out_dir)

    search_dirs = [
        out_dir,
        repo_dir / "calibrate_mat",
        repo_dir / "results",
        repo_dir / "demo" / "demo3_calibrate_psf",
        calibrate_port.parent,
    ]
    before_files = set()
    for folder in search_dirs:
        before_files |= snapshot_files(folder)

    with log_path.open("w", encoding="utf-8") as log:
        log.write("LiteLoc calibration adapter reached.\n")
        log.write(f"Started at: {now_iso()}\n")
        log.write(f"Input path: {input_path}\n")
        log.write(f"Output dir: {out_dir}\n")
        log.write(f"LiteLoc root: {repo_dir}\n")
        log.write(f"Calibration port: {calibrate_port}\n")
        log.write(f"PYTHONPATH: {env.get('PYTHONPATH', '')}\n")
        log.write("=" * 80 + "\n\n")
        log.flush()

    args = build_calibration_script_args(input_path, out_dir, profile, backend_config)
    completed = run_python_script(
        script_path=calibrate_port,
        repo_dir=repo_dir,
        log_path=log_path,
        env=env,
        extra_args=args,
    )

    artifact = find_new_artifact(
        search_dirs=search_dirs,
        before_files=before_files,
        suffixes={".mat", ".pkl", ".pickle", ".pt", ".pth", ".yaml", ".yml", ".json"},
        name_tokens=("calib", "calibration", "psf", "spline", "model"),
    )
    copied_artifact = copy_artifact_to_out_dir(artifact, out_dir)

    elapsed_seconds = round(time.time() - start_time, 3)
    status = "passed" if completed.returncode == 0 and copied_artifact else "failed"

    result = {
        "backend_name": "liteloc",
        "backend_status": status,
        "calibrate_status": status,
        "started_at": now_iso(),
        "elapsed_seconds": elapsed_seconds,
        "returncode": int(completed.returncode),
        "input_path": str(input_path),
        "out_dir": str(out_dir),
        "liteloc_root": str(repo_dir),
        "calibrate_script": str(calibrate_port),
        "calibration_args": args,
        "calibration_file": copied_artifact,
        "raw_detected_calibration_file": str(artifact) if artifact else "",
        "log_path": str(log_path),
        "status_json": str(status_path),
        "message": (
            "LiteLoc calibration completed and a calibration artifact was detected."
            if status == "passed"
            else "LiteLoc calibration did not produce a detected calibration artifact. Check liteloc_calibration.log."
        ),
    }
    write_json(result, status_path)
    return result


# =============================================================================
# Training
# =============================================================================


def build_training_script_args(
    input_path: Path,
    out_dir: Path,
    profile: Dict[str, Any],
    backend_config: Dict[str, Any],
) -> List[str]:
    raw_args = backend_config.get("training_args") or get_nested(profile, "liteloc", "training_args", default=[])
    if not raw_args:
        return []
    if not isinstance(raw_args, list):
        raise ValueError("liteloc.training_args / training_args must be a list.")

    replacements = {
        "{input}": str(input_path),
        "{output}": str(out_dir),
        "{out_dir}": str(out_dir),
        "{calibration_file}": str(backend_config.get("calibration_file", "")),
    }

    args: List[str] = []
    for item in raw_args:
        text = str(item)
        for key, value in replacements.items():
            text = text.replace(key, value)
        args.append(text)
    return args


def run_liteloc_training(
    input_path: str | Path,
    out_dir: str | Path,
    profile: Dict[str, Any],
    backend_config: Optional[Dict[str, Any]] = None,
    **_: Any,
) -> Dict[str, Any]:
    start_time = time.time()
    backend_config = dict(backend_config or {})
    input_path = Path(input_path).expanduser().resolve()
    out_dir = Path(out_dir).expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    runtime = resolve_liteloc_runtime(profile, backend_config)
    repo_dir = runtime.repo_dir
    train_port = runtime.ports.train

    log_path = out_dir / "liteloc_training.log"
    status_path = out_dir / "liteloc_training_adapter_status.json"

    if train_port is None:
        result = {
            "backend_name": "liteloc",
            "backend_status": "failed",
            "train_status": "failed",
            "model_path": "",
            "message": "No LiteLoc training port/script found. Set ports.train in adapters/backend_paths.yml.",
            "log_path": str(log_path),
        }
        write_json(result, status_path)
        return result

    env = add_liteloc_to_syspath_and_env(repo_dir)
    env["LITELOC_TRAINING_INPUT"] = str(input_path)
    env["LITELOC_TRAINING_OUTPUT"] = str(out_dir)
    env["LITELOC_RUN_OUTPUT"] = str(out_dir)

    search_dirs = [out_dir, repo_dir / "results", repo_dir / "outputs", train_port.parent]
    before_files = set()
    for folder in search_dirs:
        before_files |= snapshot_files(folder)

    with log_path.open("w", encoding="utf-8") as log:
        log.write("LiteLoc training adapter reached.\n")
        log.write(f"Started at: {now_iso()}\n")
        log.write(f"Input path: {input_path}\n")
        log.write(f"Output dir: {out_dir}\n")
        log.write(f"LiteLoc root: {repo_dir}\n")
        log.write(f"Training port: {train_port}\n")
        log.write("=" * 80 + "\n\n")
        log.flush()

    args = build_training_script_args(input_path, out_dir, profile, backend_config)
    completed = run_python_script(
        script_path=train_port,
        repo_dir=repo_dir,
        log_path=log_path,
        env=env,
        extra_args=args,
    )

    artifact = find_new_artifact(
        search_dirs=search_dirs,
        before_files=before_files,
        suffixes={".pkl", ".pickle", ".pt", ".pth", ".ckpt"},
        name_tokens=("checkpoint", "model", "liteloc", "epoch", "best"),
    )
    copied_model = copy_artifact_to_out_dir(artifact, out_dir)

    elapsed_seconds = round(time.time() - start_time, 3)
    status = "passed" if completed.returncode == 0 and copied_model else "failed"

    result = {
        "backend_name": "liteloc",
        "backend_status": status,
        "train_status": status,
        "elapsed_seconds": elapsed_seconds,
        "returncode": int(completed.returncode),
        "input_path": str(input_path),
        "out_dir": str(out_dir),
        "liteloc_root": str(repo_dir),
        "train_script": str(train_port),
        "training_args": args,
        "model_path": copied_model,
        "raw_detected_model_path": str(artifact) if artifact else "",
        "log_path": str(log_path),
        "status_json": str(status_path),
        "message": (
            "LiteLoc training completed and a model artifact was detected."
            if status == "passed"
            else "LiteLoc training did not produce a detected model artifact. Check liteloc_training.log."
        ),
    }
    write_json(result, status_path)
    return result


# =============================================================================
# Inference
# =============================================================================


def run_liteloc_one_movie(
    input_path: str | Path,
    out_dir: str | Path,
    profile: Dict[str, Any],
    backend_config: Optional[Dict[str, Any]] = None,
    **_: Any,
) -> Optional[str]:
    start_time = time.time()
    backend_config = dict(backend_config or {})
    input_path = Path(input_path).expanduser().resolve()
    out_dir = Path(out_dir).expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    runtime = resolve_liteloc_runtime(profile, backend_config)
    repo_dir = runtime.repo_dir
    infer_port = runtime.ports.infer

    if infer_port is None:
        raise FileNotFoundError(
            "No LiteLoc inference port/script found. Set ports.infer in adapters/backend_paths.yml."
        )

    env = add_liteloc_to_syspath_and_env(repo_dir)
    runtime_yaml_path, raw_output_path, resolved_runtime = build_runtime_liteloc_infer_yaml(
        input_path=input_path,
        out_dir=out_dir,
        profile=profile,
        repo_dir=repo_dir,
        backend_config=backend_config,
    )

    log_name = get_nested(profile, "output", "log_name", default="liteloc.log")
    log_path = out_dir / str(log_name)
    status_path = out_dir / "liteloc_adapter_status.json"
    infer_execution = detect_infer_execution(profile, infer_port)

    status: Dict[str, Any] = {
        "created_at": now_iso(),
        "backend": "liteloc",
        "adapter": "general_liteloc_adapter",
        "variant": get_nested(profile, "backend", "variant", default=get_nested(profile, "psf", "family", default="unspecified")),
        "input_path": str(input_path),
        "out_dir": str(out_dir),
        "repo_dir": str(repo_dir),
        "infer_port": str(infer_port),
        "infer_execution": infer_execution,
        "runtime_yaml_path": str(runtime_yaml_path),
        "raw_output_path": str(raw_output_path),
        "log_path": str(log_path),
        "resolved_runtime": resolved_runtime,
        "status": "started",
    }
    write_json(status, status_path)

    with log_path.open("w", encoding="utf-8") as log:
        log.write("LiteLoc adapter reached.\n")
        log.write("Running real LiteLoc inference through general adapter.\n\n")
        log.write(f"LiteLoc root: {repo_dir}\n")
        log.write(f"LiteLoc infer port: {infer_port}\n")
        log.write(f"Inference execution mode: {infer_execution}\n")
        log.write(f"Runtime YAML: {runtime_yaml_path}\n")
        log.write(f"Raw output path: {raw_output_path}\n")
        log.write(f"PYTHONPATH: {env.get('PYTHONPATH', '')}\n")
        log.write("=" * 80 + "\n")
        log.flush()

    try:
        if infer_execution == "script":
            completed = run_liteloc_inference_script_mode(
                infer_port=infer_port,
                runtime_yaml_path=runtime_yaml_path,
                repo_dir=repo_dir,
                env=env,
                log_path=log_path,
            )
            return_code = int(completed.returncode)
        elif infer_execution == "module":
            return_code = run_liteloc_inference_module_mode(
                runtime_yaml_path=runtime_yaml_path,
                repo_dir=repo_dir,
                log_path=log_path,
            )
        else:
            raise RuntimeError(f"Unsupported LiteLoc infer execution mode: {infer_execution}")
    except Exception as exc:
        elapsed_seconds = round(time.time() - start_time, 2)
        status.update({"status": "failed_exception", "return_code": None, "elapsed_seconds": elapsed_seconds, "message": repr(exc)})
        write_json(status, status_path)
        raise

    elapsed_seconds = round(time.time() - start_time, 2)
    status.update({"return_code": return_code, "elapsed_seconds": elapsed_seconds})

    if return_code != 0:
        status.update({"status": "failed", "message": "LiteLoc execution failed. Check liteloc.log."})
        write_json(status, status_path)
        raise RuntimeError(f"LiteLoc inference failed. Check log: {log_path}")

    if not raw_output_path.exists():
        status.update({"status": "failed_no_csv", "message": "LiteLoc finished, but expected raw CSV was not found."})
        write_json(status, status_path)
        raise FileNotFoundError(f"LiteLoc finished but did not create expected CSV: {raw_output_path}")

    status.update({"status": "real_liteloc_output_created", "message": "Real LiteLoc inference completed successfully."})
    write_json(status, status_path)
    return str(raw_output_path)


# =============================================================================
# Aliases expected by run_pipeline.py
# =============================================================================


# Calibration aliases

def run_calibration(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_calibration(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def calibrate_liteloc(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_calibration(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def run_calibrate(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_calibration(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def calibrate(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_calibration(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


# Training aliases

def run_training(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_training(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def train_liteloc(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_training(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def run_train(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_training(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def train(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Dict[str, Any]:
    return run_liteloc_training(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


# Inference aliases

def run_liteloc_inference(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Optional[str]:
    return run_liteloc_one_movie(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def run_inference_one_movie(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Optional[str]:
    return run_liteloc_one_movie(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def run_inference(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Optional[str]:
    return run_liteloc_one_movie(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def run_liteloc(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Optional[str]:
    return run_liteloc_one_movie(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)


def infer(input_path: str | Path, out_dir: str | Path, profile: Dict[str, Any], backend_config: Optional[Dict[str, Any]] = None, **kwargs: Any) -> Optional[str]:
    return run_liteloc_one_movie(input_path=input_path, out_dir=out_dir, profile=profile, backend_config=backend_config, **kwargs)
